# Stellar
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org

# Contract addresses
POOL_CONTRACT=C...
POLICY_CONTRACT=C...
ORACLE_CONTRACT=C...
TRIGGER_CONTRACT=C...

# Oracle node keypair (funded Stellar account)
ORACLE_NODE_PUBLIC_KEY=G...
ORACLE_NODE_SECRET_KEY=S...

# Database
DATABASE_URL=postgresql://ceres:password@localhost:5432/ceres_network

# API
API_PORT=3001
API_KEY=your-secret-api-key-here

# Weather APIs
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api
CHIRPS_BASE_URL=https://climateserv.servirglobal.net

# Optional webhook for payout notifications
WEBHOOK_URL=https://your-app.com/webhooks/ceres
WEBHOOK_SECRET=your-webhook-secret

# Redis (optional — for rate limiting and job deduplication)
REDIS_URL=redis://localhost:6379
